{
    "name": "Tracking Library Workspace",
    // use pre-build image for faster startup
    // docker build --no-cache -t trackinglib:latest .
    "image": "trackinglib:latest",
    
    // 1. Replicates your SSH-agent forwarding
    "runArgs": [
        "--mount", "type=bind,source=/run/host-services/ssh-auth.sock,target=/run/host-services/ssh-auth.sock"
    ],
    "containerEnv": {
        "SSH_AUTH_SOCK": "/run/host-services/ssh-auth.sock"
    },

    // AUTOMATION: Injects the path and configures the wrapper alias automatically
    "remoteEnv": {
        "PATH": "/root/.local/bin:${containerEnv:PATH}"
    },

    // 2. Replicates your workspace mount
    "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind",
    "workspaceFolder": "/workspace",

    // Extensions the AI Agent might need to work better
    "customizations": {
        "vscode": {
            "extensions": [
                "akiramiyakoda.cppincludeguard",
                "aslamanver.vsc-export",
                "cschlosser.doxdocgen",
                "donjayamanne.githistory",
                "Anthropic.claude-code",
                "github.copilot-chat",
                "github.vscode-github-actions",
                "gruntfuggly.todo-tree",
                "ibm.output-colorizer",
                "jbockle.jbockle-format-files",
                "jeff-hykin.better-cpp-syntax",
                "kilocode.kilo-code",
                "lacroixdavid1.vscode-format-context-menu",
                "llvm-vs-code-extensions.vscode-clangd",
                "markis.code-coverage",
                "matepek.vscode-catch2-test-adapter",
                "mhutchie.git-graph",
                "misq.toggleformatonsave",
                "ms-azuretools.vscode-containers",
                "ms-azuretools.vscode-docker",
                "ms-vscode.cmake-tools",
                "ms-vscode.cpp-devtools",
                "ms-vscode.hexeditor",
                "ms-vscode.live-server",
                "twxs.cmake",
                "vadimcn.vscode-lldb",
                "waderyan.gitblame",
                "zchrissirhcz.cmake-highlight"
            ]
        }
    },
    // CRITICAL: This runs every time the container is created
    "postCreateCommand": "bash .devcontainer/setup.sh"
}
