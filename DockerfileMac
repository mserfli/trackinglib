FROM ubuntu:24.04
LABEL Description="Build environment arm64"

ENV HOME=/root

SHELL ["/bin/bash", "-c"]

RUN apt-get update && apt-get -y --no-install-recommends install \
    build-essential \
    clang \
    clangd \
    cmake \
    doxygen \
    graphviz \
    octave \
    gdb \
    wget \
    git \
    ca-certificates \
    python3 \
    python3-dev \
    lcov
