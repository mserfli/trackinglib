FROM ubuntu:24.04
LABEL Description="Build environment arm64"

ENV HOME=/root

SHELL ["/bin/bash", "-c"]

RUN apt-get update && apt-get -y --no-install-recommends install \
    build-essential \
    clang \
    clangd \
    cmake \
    doxygen \
    graphviz \
    octave \
    gdb \
    wget \
    git \
    ca-certificates \
    python3 \
    python3-dev \
    perl \
    locales \
    libjson-xs-perl \
    lcov

# Set locale to German
RUN locale-gen de_DE.UTF-8
ENV LANG=de_DE.UTF-8
ENV LANGUAGE=de_DE:de
ENV LC_ALL=de_DE.UTF-8

# Install additional Perl modules
RUN cpan JSON::XS
